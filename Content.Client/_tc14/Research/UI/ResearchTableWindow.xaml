<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'research-table-ui-name'}"
                      SetSize="1200 900">
    <BoxContainer Name="ResearchTableBoxContainer"
                  Margin="10"
                  SeparationOverride="5">
        <BoxContainer Orientation="Vertical">
            <PanelContainer Name="ResearchTreeBackground"
                            StyleClasses="PanelDark"
                            MinSize="800 800">
                <ScrollContainer Name="ResearchTreeScrollContainer">
                    <LayoutContainer Name="ResearchTreeDragContainer"
                                     StyleClasses="PanelDark"
                                     RectClipContent="True"
                                     SetSize="1600 1600"/>
                </ScrollContainer>
            </PanelContainer>
            <Button Name="ResearchTreeRecenterButton"
                    Text="Recenter"
                    HorizontalExpand="False"
                    HorizontalAlignment="Center"/>
        </BoxContainer>
        <BoxContainer Name="ResearchTableSidePanel"
                         VerticalAlignment="Top"
                         HorizontalExpand="True"
                         VerticalExpand="True"
                         Orientation="Vertical"
                         SeparationOverride="5">
            <BoxContainer Name="ResearchItemDetailedPanel"
                          VerticalAlignment="Top"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          Orientation="Vertical"
                          SeparationOverride="5">
                <Label Name="ResearchItemName"
                               StyleClasses="LabelKeyText"/>
                <BoxContainer Name="ResearchItemDiscipline"
                              SeparationOverride="5">
                    <Label Text="Discipline:"/>
                    <TextureRect Name="ResearchItemDisciplineIcon"
                                 TextureScale="2 2"
                                 VerticalAlignment="Center"/>
                    <Label Name="ResearchItemDisciplineName"/>
                </BoxContainer>
                <Label Name="ResearchItemPointsNeeded"
                       Text="{Loc 'research-table-pointsneeded'}"/>
                <BoxContainer Name="ResearchItemButtons"
                              HorizontalAlignment="Center">
                    <Button Name="ResearchItemResearchButton"
                            Text="Research"
                            StyleClasses="OpenRight"/>
                    <Button Name="ResearchItemPrintButton"
                            Text="Print"
                            StyleClasses="OpenLeft"/>
                </BoxContainer>
            </BoxContainer>
            <PanelContainer StyleClasses="LowDivider" />
            <BoxContainer Name="ResearchTablePointsContainer"
                          VerticalAlignment="Top"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          Orientation="Vertical"
                          SeparationOverride="5">
                <Label Name="ResearchPointsTitle"
                       StyleClasses="LabelKeyText"
                       Text="{Loc 'research-table-pointstitle'}"/>
                <BoxContainer Name="ResearchTablePointsDisplay"
                              Orientation="Horizontal"
                              SeparationOverride="10"></BoxContainer>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
