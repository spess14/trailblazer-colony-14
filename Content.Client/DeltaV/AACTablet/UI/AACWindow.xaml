<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="AAC Tablet"
                      Resizable="True"
                      SetSize="540 300"
                      MinSize="540 300">
    <BoxContainer Orientation="Vertical">
        <!-- Content -->
        <TabContainer HorizontalExpand="True" VerticalExpand="True" Name="Content">
            <!-- Populated programmatically -->
        </TabContainer>

        <!-- Footer -->
        <BoxContainer Orientation="Horizontal" MinHeight="28" HorizontalExpand="True">
            <Label Name="Footer"
                   Text="{Loc 'aac-window-footer-flavor'}"
                   StyleClasses="WindowFooterText"
                   HorizontalAlignment="Right"
                   HorizontalExpand="True"
                   Margin="0 0 4 4" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
